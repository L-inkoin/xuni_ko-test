install.packages("scTenifoldKnk")
library(scTenifoldKnk)
library(Seurat)
library(ggplot2)
library(ggrepel)
library(dplyr)
library(hdf5r)

# 数据读取
h5_files <- list.files(path = "F:/xuni/data", pattern = "\\.h5$", full.names = TRUE)
sample_names <- gsub("_raw_feature_bc_matrix\\.h5$", "", basename(h5_files))
sc_list <- list()
for(i in seq_along(h5_files)){
  data <- Read10X_h5(h5_files[i])
  obj <- CreateSeuratObject(counts = data, 
                            project = sample_names[i], 
                            min.cells = 3, 
                            min.features = 200)
  sc_list[[i]] <- obj
}
pbmc <- merge(sc_list[[1]], y = sc_list[-1], add.cell.ids = sample_names)
pbmc$Type <- ifelse(grepl("HT", pbmc$orig.ident), "Tumor", "Normal")
seurat_obj <- subset(pbmc, subset = Type == "Tumor")
seurat_obj <- JoinLayers(seurat_obj) 

# 提取表达矩阵
count_matrix <- GetAssayData(seurat_obj, layer = "counts")
# 定义要敲除的基因
target_genes <- c("SPP1", "AKR1C3", "MMP9", "CDK4", "LGALS1")
comb_name <- "Combined_5_Genes"

seurat_obj <- FindVariableFeatures(object=seurat_obj, selection.method="vst", nfeatures=2000)
high_variable_genes <- VariableFeatures(seurat_obj)
# 创建输出目录
if(!dir.exists("scTenifoldKnk_Results")) dir.create("scTenifoldKnk_Results")
# 多基因敲除方案：逐个敲除并整合结果
all_diff_reg <- list()
for(gene in target_genes) {
  cat("Processing knockout for:", gene, "\n")
  count_matrix_mod <- count_matrix
  count_matrix_mod[gene, ] <- 0
  genes_to_keep <- unique(c(gene, high_variable_genes))
  input_data <- as.matrix(count_matrix_mod[genes_to_keep, ])
  tryCatch({
    ko_res <- scTenifoldKnk(countMatrix = input_data,
                            gKO = gene,      #需要敲除的基因
                            qc = TRUE,                #是否进行QC
                            qc_mtThreshold = 0.1,        #mt的阈值
                            qc_minLSize = 1000,         #文库阈值(细胞测到的基因总数)
                            nc_nNet = 10,              #子网络数量
                            nc_nCells = 500            #每个网络中随机抽取的细胞数
    )

    diff_reg <- ko_res$diffRegulation
    diff_reg$knocked_gene <- gene  # 标记敲除的基因
    diff_reg <- diff_reg[!(diff_reg$gene %in% target_genes), ]
    all_diff_reg[[gene]] <- diff_reg
  }, error = function(e) {
    cat("Error processing", gene, ":", e$message, "\n")
  })
}

combined_diff <- bind_rows(all_diff_reg)

# 计算综合得分
combined_summary <- combined_diff %>%
  group_by(gene) %>%
  summarise(
    mean_FC = mean(FC, na.rm = TRUE),
    max_FC = max(FC, na.rm = TRUE),
    min_p_adj = min(p.adj, na.rm = TRUE),
    combined_score = mean(abs(FC) * -log10(p.adj + 1e-10), na.rm = TRUE),
    knockout_count = n()
  ) %>%
  arrange(desc(combined_score))
# 保存结果
write.csv(combined_diff, file = "scTenifoldKnk_Results/Combined_Knockout_Results.csv", row.names = FALSE)
write.csv(combined_summary, file = "scTenifoldKnk_Results/Gene_Summary_Scores.csv", row.names = FALSE)

