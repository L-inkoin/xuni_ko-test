# ******** top20差异基因变量 ********
top20_diff_genes <- head(combined_diff[order(-combined_diff$FC), ], 20)
p1=ggplot(top20_diff_genes, aes(x=reorder(gene, FC), y=FC)) +
  geom_bar(stat='identity', fill='#5A9BD4') +
  coord_flip() + 
  labs(title="Top 20 Differentially Regulated Genes", x="Gene", y="FC") +
  theme_minimal() + theme(plot.title = element_text(hjust = 0.5))
#输出图形
pdf(file="barplot-F.pdf", width=6, height=5)
print(p1)
dev.off()
combined_diff$log_p.adj <- -log10(combined_diff$p.adj)
combined_diff$significant <- ifelse(combined_diff$p.adj < 0.05, "Significant", "Not significant")
labeled_significant_genes <- subset(combined_diff, p.adj < 0.05)

# 绘制火山图
combined_diff$log_p.adj <- -log10(combined_diff$p.adj)
combined_diff$group <- "Not significant"
combined_diff$group[combined_diff$p.adj < 0.05 & combined_diff$Z > 1.96] <- "Up"
combined_diff$group[combined_diff$p.adj < 0.05 & combined_diff$Z < -1.96] <- "Down"
labeled_significant_genes <- combined_diff %>% 
  filter(p.adj < 0.05) %>% 
  arrange(desc(log_p.adj)) %>% 
  head(10)
p2 = ggplot(combined_diff, aes(x=Z, y=log_p.adj, color=group)) +
  geom_point(alpha=0.6, size=1.2) + 
  # 颜色设置：红色上调，蓝色下调，灰色不显著
  scale_color_manual(values = c("Up" = "#E41A1C", "Down" = "#377EB8", "Not significant" = "gray80")) +
  # 添加参考线
  geom_vline(xintercept = c(-1.96, 1.96), linetype = "dotted", color = "black") +
  geom_hline(yintercept = -log10(0.05), linetype = "dashed", color = "red") +
  # 标注基因名称
  geom_text_repel(data = labeled_significant_genes, 
                  aes(label = gene), 
                  size = 3,
                  box.padding = 0.5,     
                  point.padding = 0.3,   
                  max.overlaps = Inf,    
                  show.legend = FALSE,
                  segment.color = 'gray50') +
  labs(title = "Volcano Plot: F Analysis", 
       x = "Z-score (Differential Regulation)", 
       y = "-log10(Adjusted P-value)") +
  theme_classic() + 
  theme(legend.position = "right") +
  coord_cartesian(ylim = c(0, 50))
ggsave("vol1-F.pdf", plot = p2, width = 6, height = 5)

# 绘制饼图
significant_gene_count <- table(combined_diff$significant)
